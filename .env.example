# ─────────────────────────────────────────────
# RE/MAX Impacta — Agente de Cobros
# Copiar este archivo como .env y completar los valores
# ─────────────────────────────────────────────

# ID del Google Sheet de cobros (parte de la URL: /d/SHEET_ID/edit)
GOOGLE_SHEET_ID=PENDIENTE

# Credenciales de Google Service Account en una sola línea (JSON completo)
GOOGLE_SERVICE_ACCOUNT_JSON=PENDIENTE

# Número WhatsApp del equipo administrativo para alertas de cobros sin pagar
# Formato: código de país + número, sin + (ej: 593991234567)
NUMERO_ADMIN=PENDIENTE

# Día del mes en que vence el pago (todos los asesores tienen la misma fecha)
DIA_VENCIMIENTO=5

# Día del mes en que se envía el primer recordatorio (3 días antes del vencimiento)
DIA_INICIO_RECORDATORIO=2

# Días entre cada seguimiento
DIAS_ENTRE_SEGUIMIENTOS=5

# Datos bancarios para transferencia (se incluyen en todos los mensajes)
# Separar líneas con \n si se necesitan múltiples líneas
DATOS_BANCARIOS=PENDIENTE — completar con banco, cuenta, titular y RUC/cédula

# Path del volumen Railway donde Baileys persiste la sesión
RAILWAY_VOLUME_MOUNT_PATH=/data

# Cron: lunes a viernes a las 9:00
CRON_SCHEDULE=0 9 * * 1-5

# Zona horaria Ecuador
TIMEZONE=America/Guayaquil

# Token para proteger el endpoint /run-now
ADMIN_TOKEN=cambiar_por_token_seguro

# Puerto del servidor HTTP
PORT=3000
